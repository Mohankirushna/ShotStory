# ShotStory Backend Configuration
# Copy this file to .env and customize as needed

# ============================================================================
# RECOMMENDED: Preload models during server startup for faster first request
# ============================================================================
# Set to true to load all AI models when server starts (2-5 minute startup)
# Set to false for fast startup, but first request will be slow (5+ minutes)
PRELOAD_MODELS=false

# ============================================================================
# Debug Mode
# ============================================================================
# Enable verbose logging for troubleshooting
DEBUG=false

# ============================================================================
# AI Model Configuration
# ============================================================================
# All models will be downloaded from HuggingFace and cached locally
# Only change these if you want to use different/lighter models

# Image captioning model (generates image descriptions)
CAPTION_MODEL=Salesforce/blip-image-captioning-base

# Visual Question Answering model (extracts scene attributes)
VQA_MODEL=Salesforce/blip-vqa-base

# Object detection model (detects objects and their locations)
DETECTION_MODEL=facebook/detr-resnet-50

# Story generation model (creates narrative from image analysis)
# Options:
#   google/flan-t5-large  (best quality, 3GB, slower)
#   google/flan-t5-base   (lighter, 1GB, faster but lower quality)
STORY_MODEL=google/flan-t5-large

# ============================================================================
# Object Detection Settings
# ============================================================================
# Confidence threshold for object detection (0.0 - 1.0)
# Lower = more detections but may include false positives
# Higher = fewer detections but more confident
DETECTION_THRESHOLD=0.5

# ============================================================================
# Story Generation Settings
# ============================================================================
# Maximum number of tokens (words) in generated story
STORY_MAX_TOKENS=512

# Temperature controls creativity (0.0 - 2.0)
# Lower (0.1-0.5) = more deterministic, factual
# Medium (0.7-0.9) = balanced creativity
# Higher (1.0-2.0) = more creative, varied, sometimes random
STORY_TEMPERATURE=0.9

# ============================================================================
# HuggingFace Token (Optional)
# ============================================================================
# Set this for:
# - Faster model downloads (higher rate limits)
# - Access to gated/private models
# Get a free token at: https://huggingface.co/settings/tokens
# HF_TOKEN=hf_your_token_here

# ============================================================================
# Performance Tuning (Advanced)
# ============================================================================
# Force CPU mode (disable GPU) - useful if CUDA causes issues
# CUDA_VISIBLE_DEVICES=""

# Set PyTorch thread count (default: auto-detect)
# OMP_NUM_THREADS=4
